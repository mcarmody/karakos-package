DISCORD_BOT_TOKEN_PRIMARY=MTIz...
DISCORD_BOT_ID_PRIMARY=1234567890123456
# DISCORD_BOT_TOKEN_RELAY=NTY4...    # Optional — falls back to primary
# DISCORD_BOT_ID_RELAY=2345678901234567
DISCORD_SERVER_ID=1234567889

# === Discord channels ===
DISCORD_CHANNEL_GENERAL=1234567890
DISCORD_CHANNEL_SIGNALS=1234567891

# === System identity ===
SYSTEM_NAME=Karakos
OWNER_NAME=User
OWNER_DISCORD_ID=0
WORKSPACE_ROOT=/workspace

# === Network ===
DASHBOARD_PORT=3000
AGENT_SERVER_PORT=18791
TZ=America/Los_Angeles

# === Cost limits ===
COST_DAILY_LIMIT=25.00
COST_MONTHLY_LIMIT=500.00
COST_WARNING_THRESHOLD=0.75

# === Concurrency ===
MAX_CONCURRENT_BUILDERS=1
